---
interface PageSummary {
  pageNum: number;
  label: string;
  type: string;
  category: string;
  difficulty: string;
}

interface Props {
  currentPage?: number;
  bookId?: string;
  pages?: PageSummary[];
}

const { currentPage = 1, bookId = 'nfl', pages = [] } = Astro.props as Props;

const uniqueTypes = [...new Set(pages.map(p => p.type))].sort();
const uniqueCategories = [...new Set(pages.map(p => p.category).filter(Boolean))].sort();
const difficultyOrder = ['Easy', 'Medium', 'Hard'];
const uniqueDifficulties = [...new Set(pages.map(p => p.difficulty).filter(Boolean))].sort((a, b) => difficultyOrder.indexOf(a) - difficultyOrder.indexOf(b));
---

<header class="bg-blue-600 text-white shadow-lg print:hidden">
  <div class="container mx-auto px-4 py-3 sm:px-6 sm:py-5 flex flex-col gap-2 sm:flex-row sm:flex-wrap sm:items-center sm:gap-3">

    <!-- Row 1 on mobile: sport toggle + print button -->
    <div class="flex items-center gap-2">

      <!-- Sport toggle -->
      <div class="flex rounded overflow-hidden border border-white/40 text-sm font-semibold shrink-0">
        <a
          href="/barbooks/nfl/1/"
          class={`px-3 py-1.5 transition-colors ${bookId === 'nfl' ? 'bg-white text-blue-600' : 'hover:bg-white/10'}`}
        >NFL</a>
        <a
          href="/barbooks/nba/1/"
          class={`px-3 py-1.5 transition-colors border-l border-white/40 ${bookId === 'nba' ? 'bg-white text-blue-600' : 'hover:bg-white/10'}`}
        >NBA</a>
      </div>

      <!-- Print button (mobile: in top row; desktop: pushed to far right via ml-auto on sm+) -->
      <button
        class="ml-auto sm:hidden shrink-0 bg-green-500 hover:bg-green-600 text-white px-4 py-1.5 rounded text-sm font-medium transition-colors"
        onclick="window.print()"
      >
        Print
      </button>
    </div>

    <!-- Row 2 on mobile / inline on desktop: filters + page select -->
    <div class="flex flex-wrap items-center gap-2 sm:contents">

      <!-- Type filter -->
      <select
        id="type-filter"
        class="px-2 py-1.5 text-sm text-black rounded bg-white cursor-pointer"
      >
        <option value="">All Types</option>
        {uniqueTypes.map(type => (
          <option value={type}>{type.charAt(0).toUpperCase() + type.slice(1)}</option>
        ))}
      </select>

      <!-- Category filter -->
      {uniqueCategories.length > 0 && (
        <select
          id="category-filter"
          class="px-2 py-1.5 text-sm text-black rounded bg-white cursor-pointer"
        >
          <option value="">All Categories</option>
          {uniqueCategories.map(cat => (
            <option value={cat}>{cat}</option>
          ))}
        </select>
      )}

      <!-- Difficulty filter -->
      {uniqueDifficulties.length > 0 && (
        <select
          id="difficulty-filter"
          class="px-2 py-1.5 text-sm text-black rounded bg-white cursor-pointer"
        >
          <option value="">All Difficulties</option>
          {uniqueDifficulties.map(d => (
            <option value={d}>{d}</option>
          ))}
        </select>
      )}

      <!-- Pages dropdown -->
      <select
        id="page-select"
        class="flex-1 min-w-0 px-2 py-1.5 text-sm text-black rounded bg-white cursor-pointer"
      >
        {pages.map(p => (
          <option value={p.pageNum} data-type={p.type} data-category={p.category} data-difficulty={p.difficulty} selected={p.pageNum === currentPage}>
            {p.pageNum}. {p.label}
          </option>
        ))}
      </select>
    </div>

    <!-- Print button (desktop only, pushed right) -->
    <button
      class="hidden sm:block ml-auto shrink-0 bg-green-500 hover:bg-green-600 text-white px-4 py-1.5 rounded text-sm font-medium transition-colors"
      onclick="window.print()"
    >
      Print Page
    </button>

  </div>
</header>

<script define:vars={{ bookId }}>
  const typeFilter = document.getElementById('type-filter');
  const categoryFilter = document.getElementById('category-filter');
  const difficultyFilter = document.getElementById('difficulty-filter');
  const pageSelect = document.getElementById('page-select');

  function getFilterParams() {
    const params = new URLSearchParams();
    if (typeFilter?.value) params.set('type', typeFilter.value);
    if (categoryFilter?.value) params.set('category', categoryFilter.value);
    if (difficultyFilter?.value) params.set('difficulty', difficultyFilter.value);
    return params;
  }

  function navigateTo(pageNum) {
    const params = getFilterParams();
    const qs = params.toString();
    window.location.href = `/barbooks/${bookId}/${pageNum}/` + (qs ? `?${qs}` : '');
  }

  function restoreFilters() {
    const params = new URLSearchParams(window.location.search);
    if (typeFilter && params.has('type')) typeFilter.value = params.get('type');
    if (categoryFilter && params.has('category')) categoryFilter.value = params.get('category');
    if (difficultyFilter && params.has('difficulty')) difficultyFilter.value = params.get('difficulty');
  }

  function applyFilters(navigate = false) {
    const selectedType = typeFilter ? typeFilter.value : '';
    const selectedCategory = categoryFilter ? categoryFilter.value : '';
    const selectedDifficulty = difficultyFilter ? difficultyFilter.value : '';
    Array.from(pageSelect.options).forEach(opt => {
      const typeMatch = !selectedType || opt.dataset.type === selectedType;
      const catMatch = !selectedCategory || opt.dataset.category === selectedCategory;
      const diffMatch = !selectedDifficulty || opt.dataset.difficulty === selectedDifficulty;
      opt.hidden = !(typeMatch && catMatch && diffMatch);
    });
    if (navigate && pageSelect.selectedOptions[0]?.hidden) {
      const first = Array.from(pageSelect.options).find(o => !o.hidden);
      if (first) navigateTo(first.value);
    }
  }

  if (pageSelect) {
    restoreFilters();
    applyFilters();

    typeFilter?.addEventListener('change', () => applyFilters(true));
    categoryFilter?.addEventListener('change', () => applyFilters(true));
    difficultyFilter?.addEventListener('change', () => applyFilters(true));

    pageSelect.addEventListener('change', () => {
      const pageNum = pageSelect.value;
      if (pageNum) navigateTo(pageNum);
    });
  }
</script>
