---
import QRCode from 'qrcode';
import { getBookSide } from '../utils/pageUtils.js';

interface Props {
  currentPage?: number;
  answerKeyUrl?: string;
}

const { currentPage = 1, answerKeyUrl } = Astro.props as Props;

const qrSvg = answerKeyUrl
  ? await QRCode.toString(answerKeyUrl, { type: 'svg', margin: 1, width: 48, color: { dark: '#000000', light: '#ffffff' } })
  : null;

const side = getBookSide(currentPage);
const isOdd = side === 'right';
---

<!-- Print footer that appears at bottom of printed pages -->
<div class="print-footer">
  <div class="footer-stripe">
    <div class="page-num-slot">
      {isOdd ? <span class="page-num">{currentPage}</span> : <span class="answer-key-label">Scan for Answer Key</span>}
    </div>
    <div class="qr-container">
      {qrSvg && <Fragment set:html={qrSvg} />}
    </div>
    <div class="page-num-slot right">
      {!isOdd ? <span class="page-num">{currentPage}</span> : <span class="answer-key-label">Scan for Answer Key</span>}
    </div>
  </div>
</div>

<style>
  .print-footer {
    display: none;
  }

  @media print {
    .print-footer {
      display: block !important;
      margin-top: auto;
      margin-left: -0.75in;
      margin-right: -0.75in;
      margin-bottom: -0.5in;
      print-color-adjust: exact;
      -webkit-print-color-adjust: exact;
    }

    .footer-stripe {
      background: transparent;
      border-top: 2px solid #111;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 0.75in;
      print-color-adjust: exact;
      -webkit-print-color-adjust: exact;
    }

    .page-num-slot {
      width: 40px;
      display: flex;
      align-items: center;
    }

    .page-num-slot.right {
      justify-content: flex-end;
    }

    .page-num {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 18px;
      color: #111;
      letter-spacing: 0.1em;
    }

    .qr-container svg {
      width: 36px;
      height: 36px;
      display: block;
    }

    .answer-key-label {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 7px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #999;
    }
  }
</style>
