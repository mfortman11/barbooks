---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
// Swap between header designs:
// import PageHeader from '../components/PageHeader.astro';
import PageHeader from '../components/PageHeaderScorecard.astro';
// import PageHeader from '../components/PageHeaderMagazine.astro';
import PageFooter from '../components/PageFooter.astro';
import type { ActionContent, PageDifficulty, PageType } from '../utils/pageTypes.js';
import { booksConfig } from '../utils/pageConfig.js';

interface Props {
  title: string;
  currentPage?: number;
  answerKeyUrl?: string;
  bookId?: string;
  pageTitle?: string;
  pageDescription?: string;
  category?: string;
  difficulty?: PageDifficulty;
  actionContent?: ActionContent;
  itemCount?: number;
  pageType?: PageType;
}

const { title, currentPage = 1, answerKeyUrl, bookId = 'nfl', pageTitle, pageDescription, category, difficulty, actionContent, itemCount, pageType } = Astro.props as Props;

const book = booksConfig[bookId];
const totalPages = book?.pages.length ?? 0;
const pagesSummary = book ? book.pages.map((page, i) => ({
  pageNum: i + 1,
  label: ('title' in page && page.title) ? page.title : `(${page.type})`,
  type: page.type,
  category: ('category' in page && page.category) ? page.category : '',
  difficulty: ('difficulty' in page && page.difficulty) ? page.difficulty : '',
})) : [];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title class="print:hidden">{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=Barlow+Condensed:wght@300;400;700;900&family=Bebas+Neue&family=IBM+Plex+Mono:wght@400;700&display=swap" rel="stylesheet">
</head>
<body class="bg-white min-h-screen flex flex-col">
  <div id="app" class="flex flex-col flex-1 print:h-full">
    <SiteHeader currentPage={currentPage} bookId={bookId} pages={pagesSummary} />
    <PageHeader title={title} currentPage={currentPage} pageTitle={pageTitle} pageDescription={pageDescription} category={category} difficulty={difficulty} actionContent={actionContent} bookId={bookId} itemCount={itemCount} pageType={pageType} />
    <main class="flex-1 container mx-auto px-4 print:p-0 print:m-0 print:max-w-none print:flex print:flex-col print:justify-center">
      <slot />
    </main>
    <SiteFooter currentPage={currentPage} totalPages={totalPages} />
    <PageFooter currentPage={currentPage} answerKeyUrl={answerKeyUrl} />
  </div>
  
  <script define:vars={{ currentPage, totalPages, answerKeyUrl, bookId }}>
    window.bookAppConfig = {
      currentPage,
      totalPages,
      answerKeyUrl: answerKeyUrl || `https://example.com/page-${currentPage}-answers`,
      bookId
    };
  </script>
  <script src="/src/scripts/bookApp.ts"></script>
</body>
</html>