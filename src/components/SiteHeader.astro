---
interface PageSummary {
  pageNum: number;
  label: string;
  type: string;
  category: string;
  difficulty: string;
}

interface Props {
  currentPage?: number;
  bookId?: string;
  pages?: PageSummary[];
}

const { currentPage = 1, bookId = 'nfl', pages = [] } = Astro.props as Props;

const uniqueTypes = [...new Set(pages.map(p => p.type))].sort();
const uniqueCategories = [...new Set(pages.map(p => p.category).filter(Boolean))].sort();
const difficultyOrder = ['Easy', 'Medium', 'Hard'];
const uniqueDifficulties = [...new Set(pages.map(p => p.difficulty).filter(Boolean))].sort((a, b) => difficultyOrder.indexOf(a) - difficultyOrder.indexOf(b));
---

<header class="bg-blue-600 text-white shadow-lg print:hidden">
  <div class="container mx-auto px-6 py-5 flex items-center gap-3">

    <!-- Sport toggle -->
    <div class="flex rounded overflow-hidden border border-white/40 text-sm font-semibold shrink-0">
      <a
        href="/barbooks/nfl/1/"
        class={`px-3 py-1.5 transition-colors ${bookId === 'nfl' ? 'bg-white text-blue-600' : 'hover:bg-white/10'}`}
      >NFL</a>
      <a
        href="/barbooks/nba/1/"
        class={`px-3 py-1.5 transition-colors border-l border-white/40 ${bookId === 'nba' ? 'bg-white text-blue-600' : 'hover:bg-white/10'}`}
      >NBA</a>
    </div>

    <!-- Type filter -->
    <select
      id="type-filter"
      class="px-2 py-1.5 text-sm text-black rounded bg-white cursor-pointer shrink-0"
    >
      <option value="">All Types</option>
      {uniqueTypes.map(type => (
        <option value={type}>{type.charAt(0).toUpperCase() + type.slice(1)}</option>
      ))}
    </select>

    <!-- Category filter -->
    {uniqueCategories.length > 0 && (
      <select
        id="category-filter"
        class="px-2 py-1.5 text-sm text-black rounded bg-white cursor-pointer shrink-0"
      >
        <option value="">All Categories</option>
        {uniqueCategories.map(cat => (
          <option value={cat}>{cat}</option>
        ))}
      </select>
    )}

    <!-- Difficulty filter -->
    {uniqueDifficulties.length > 0 && (
      <select
        id="difficulty-filter"
        class="px-2 py-1.5 text-sm text-black rounded bg-white cursor-pointer shrink-0"
      >
        <option value="">All Difficulties</option>
        {uniqueDifficulties.map(d => (
          <option value={d}>{d}</option>
        ))}
      </select>
    )}

    <!-- Pages dropdown -->
    <select
      id="page-select"
      class="px-2 py-1.5 text-sm text-black rounded bg-white cursor-pointer"
    >
      {pages.map(p => (
        <option value={p.pageNum} data-type={p.type} data-category={p.category} data-difficulty={p.difficulty} selected={p.pageNum === currentPage}>
          {p.pageNum}. {p.label}
        </option>
      ))}
    </select>

    <!-- Print button -->
    <button
      class="ml-auto shrink-0 bg-green-500 hover:bg-green-600 text-white px-4 py-1.5 rounded text-sm font-medium transition-colors"
      onclick="window.print()"
    >
      Print Page
    </button>

  </div>
</header>

<script define:vars={{ bookId }}>
  const typeFilter = document.getElementById('type-filter');
  const categoryFilter = document.getElementById('category-filter');
  const difficultyFilter = document.getElementById('difficulty-filter');
  const pageSelect = document.getElementById('page-select');

  function applyFilters() {
    const selectedType = typeFilter ? typeFilter.value : '';
    const selectedCategory = categoryFilter ? categoryFilter.value : '';
    const selectedDifficulty = difficultyFilter ? difficultyFilter.value : '';
    Array.from(pageSelect.options).forEach(opt => {
      const typeMatch = !selectedType || opt.dataset.type === selectedType;
      const catMatch = !selectedCategory || opt.dataset.category === selectedCategory;
      const diffMatch = !selectedDifficulty || opt.dataset.difficulty === selectedDifficulty;
      opt.hidden = !(typeMatch && catMatch && diffMatch);
    });
    if (pageSelect.selectedOptions[0]?.hidden) {
      const first = Array.from(pageSelect.options).find(o => !o.hidden);
      if (first) pageSelect.value = first.value;
    }
  }

  if (pageSelect) {
    typeFilter?.addEventListener('change', applyFilters);
    categoryFilter?.addEventListener('change', applyFilters);
    difficultyFilter?.addEventListener('change', applyFilters);

    pageSelect.addEventListener('change', () => {
      const pageNum = pageSelect.value;
      if (pageNum) window.location.href = `/barbooks/${bookId}/${pageNum}/`;
    });
  }
</script>
