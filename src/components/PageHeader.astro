---
import ActionContent from './ActionContent.astro';
import type { ActionContent as ActionContentType, PageDifficulty } from '../utils/pageTypes.js';

interface Props {
  title?: string;
  currentPage?: number;
  pageTitle?: string;
  pageDescription?: string;
  category?: string;
  difficulty?: PageDifficulty;
  actionContent?: ActionContentType;
}

const { title = "Book Page", currentPage = 1, pageTitle, pageDescription, category, difficulty, actionContent } = Astro.props as Props;

const difficultyColors: Record<PageDifficulty, string> = {
  Easy:   'bg-green-100 text-green-800 print:bg-transparent print:text-black print:border print:border-green-800',
  Medium: 'bg-yellow-100 text-yellow-800 print:bg-transparent print:text-black print:border print:border-yellow-800',
  Hard:   'bg-red-100 text-red-800 print:bg-transparent print:text-black print:border print:border-red-800',
};
---

<!-- Page header that appears on printed pages and book content -->
<div class="page-header pt-20 print:pt-4 relative">
  {actionContent && (
    <ActionContent
      content={actionContent.content}
      position={actionContent.position}
      rotation={actionContent.rotation}
      icon={actionContent.icon}
    />
  )}

  <div class="text-center mb-4">
    {pageTitle ? (
      <h1 class="text-xl font-bold print:text-black print:text-lg">{pageTitle}</h1>
    ) : (
      <h1 class="text-xl font-bold">{title}</h1>
    )}
    {pageDescription && (
      <p class="text-sm text-gray-600 print:text-black print:text-xs mt-2">{pageDescription}</p>
    )}
    {(category || difficulty) && (
      <div class="flex items-center justify-center gap-2 mt-2">
        {category && (
          <span class="text-xs font-medium px-2 py-0.5 rounded bg-blue-100 text-blue-800 print:bg-transparent print:text-black print:border print:border-blue-800">{category}</span>
        )}
        {difficulty && (
          <span class={`text-xs font-medium px-2 py-0.5 rounded ${difficultyColors[difficulty]}`}>{difficulty}</span>
        )}
      </div>
    )}
  </div>
</div>