---
import ActionContent from './ActionContent.astro';
import Badge from './Badge.astro';
import type { ActionContent as ActionContentType, PageDifficulty } from '../utils/pageTypes.js';

interface Props {
  title?: string;
  currentPage?: number;
  pageTitle?: string;
  pageDescription?: string;
  category?: string;
  difficulty?: PageDifficulty;
  actionContent?: ActionContentType;
}

const { title = "Book Page", currentPage = 1, pageTitle, pageDescription, category, difficulty, actionContent } = Astro.props as Props;

---

<!-- Page header that appears on printed pages and book content -->
<div class="page-header pt-20 print:pt-4 relative">
  {actionContent && (
    <ActionContent
      content={actionContent.content}
      position={actionContent.position}
      rotation={actionContent.rotation}
      icon={actionContent.icon}
    />
  )}

  <div class="text-center print:text-left mb-4">
    {pageTitle ? (
      <h1 class="text-xl font-bold print:text-black print:text-lg">{pageTitle}</h1>
    ) : (
      <h1 class="text-xl font-bold">{title}</h1>
    )}
    {pageDescription && (
      <p class="text-sm text-gray-600 print:text-black print:text-xs mt-2">{pageDescription}</p>
    )}
    {(category || difficulty) && (
      <div class="flex items-center justify-center print:justify-start gap-2 mt-2">
        {category && <Badge label="Category" value={category} />}
        {difficulty && <Badge label="Difficulty" value={difficulty} />}
      </div>
    )}
  </div>
</div>