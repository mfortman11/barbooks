---
import type { ActionContent as ActionContentType, PageDifficulty } from '../utils/pageTypes.js';

interface Props {
  title?: string;
  currentPage?: number;
  pageTitle?: string;
  pageDescription?: string;
  category?: string;
  difficulty?: PageDifficulty;
  actionContent?: ActionContentType;
  bookId?: string;
}

const { title = "Book Page", currentPage = 1, pageTitle, pageDescription, category, difficulty, bookId = 'nfl' } = Astro.props as Props;

const displayTitle = pageTitle || title;
const difficultyLevel = difficulty === 'Easy' ? 1 : difficulty === 'Medium' ? 2 : difficulty === 'Hard' ? 3 : 0;
---

<div class="header-outer pt-20 print:pt-0">
  <div class="magazine-wrap">
    <div class="slash-bg"></div>
    <div class="mag-content">
      <div class="brand-row">
        <div class="brand-name">Do You Know Ball?</div>
        <div class="brand-divider"></div>
        <div class="page-num">{bookId.toUpperCase()} · Q.{String(currentPage).padStart(2, '0')}</div>
      </div>
      <div class="question-title">{displayTitle}</div>
      {pageDescription && (
        <div class="instructions">{pageDescription}</div>
      )}
      <div class="tags">
        {category && <div class="tag filled">{category}</div>}
        {difficulty && (
          <div class="difficulty-bar">
            <span class="bar-label">{difficulty}</span>
            <div class="bars">
              <span class:list={['bar', { active: difficultyLevel >= 1 }]}></span>
              <span class:list={['bar', { active: difficultyLevel >= 2 }]}></span>
              <span class:list={['bar', { active: difficultyLevel >= 3 }]}></span>
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
</div>

<style>
  @media print {
    .header-outer {
      margin-left: -0.75in;
      margin-right: -0.75in;
      margin-top: -0.5in;
    }
  }

  .magazine-wrap {
    background: #fff;
    position: relative;
    overflow: hidden;
    border: 1px solid #ddd;
    print-color-adjust: exact;
    -webkit-print-color-adjust: exact;
  }

  .slash-bg {
    position: absolute;
    top: 0; right: 0;
    width: 220px;
    height: 100%;
    background: #111;
    clip-path: polygon(40px 0, 100% 0, 100% 100%, 0 100%);
    z-index: 0;
    print-color-adjust: exact;
    -webkit-print-color-adjust: exact;
  }

  .mag-content {
    position: relative;
    z-index: 1;
    padding: 24px 28px;
  }

  .brand-row {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 18px;
  }

  .brand-name {
    font-family: 'Anton', sans-serif;
    font-size: 13px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #111;
    white-space: nowrap;
  }

  .brand-divider {
    flex: 1;
    height: 1px;
    background: #ccc;
  }

  .page-num {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: #999;
    white-space: nowrap;
  }

  .question-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 38px;
    line-height: 0.95;
    text-transform: uppercase;
    color: #111;
    max-width: 420px;
    margin-bottom: 14px;
  }

  .instructions {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 300;
    font-size: 14px;
    letter-spacing: 0.05em;
    color: #555;
    max-width: 380px;
    margin-bottom: 20px;
    text-transform: uppercase;
  }

  .tags {
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .tag {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 5px 12px;
    border: 1.5px solid #111;
    color: #111;
  }

  .tag.filled {
    background: #111;
    color: #fff;
    print-color-adjust: exact;
    -webkit-print-color-adjust: exact;
  }

  .difficulty-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-left: auto;
  }

  .bar-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #999;
  }

  .bars {
    display: flex;
    gap: 3px;
    align-items: flex-end;
    height: 18px;
  }

  .bar {
    width: 6px;
    background: #ddd;
    display: block;
    print-color-adjust: exact;
    -webkit-print-color-adjust: exact;
  }

  .bar:nth-child(1) { height: 6px; }
  .bar:nth-child(2) { height: 12px; }
  .bar:nth-child(3) { height: 18px; }

  .bar.active { background: #111; }
</style>
